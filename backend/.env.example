# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string-in-prod
APP_BASE_URL=http://localhost:8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://andiamo:andiamo@localhost:5433/andiamo
DATABASE_URL_SYNC=postgresql+psycopg://andiamo:andiamo@localhost:5433/andiamo

# --- JWT ---
JWT_SECRET=dev-jwt-secret-change-me-in-production
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (S3 compatible — MinIO in dev, Hetzner Object Storage in prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=andiamo-media

# --- AI providers (optional in dev) ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Email (dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@andiamo.local

# --- CORS (comma-separated origins) ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
